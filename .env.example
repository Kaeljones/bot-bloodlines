# Configurações do Discord Bot
DISCORD_TOKEN=seu_token_aqui
DISCORD_CLIENT_ID=seu_client_id_aqui

# ID do Servidor para registro rápido de comandos em ambiente de desenvolvimento (Opcional)
# Se não preenchido, os comandos serão registrados globalmente (pode levar até 1 hora para propagar)
DEVELOPMENT_GUILD_ID=

# Configurações do Banco de Dados MySQL
DATABASE_URL="mysql://root:rootpassword@localhost:3306/bloodlines_db"

# Porta da aplicação (se aplicável)
PORT=3000
